{
  "name": "prodx",
  "version": "0.2.0",
  "private": true,
  "type": "module",
  "description": "Scaffold CLI for Shopify catalog management with Convex, Trigger.dev, and Paperclip.",
  "workspaces": [
    "apps/web"
  ],
  "bin": {
    "prodx": "./dist/index.js"
  },
  "scripts": {
    "build": "tsc",
    "setup": "tsx src/index.ts",
    "start": "npm run build && node dist/index.js",
    "typecheck": "tsc --noEmit"
  },
  "engines": {
    "node": ">=22"
  },
  "dependencies": {
    "@clack/prompts": "^0.9.1",
    "@trigger.dev/sdk": "4.4.4",
    "convex": "^1.21.0",
    "dotenv": "^16.4.7",
    "openai": "^4.85.0",
    "picocolors": "^1.1.1"
  },
  "devDependencies": {
    "@trigger.dev/build": "4.4.4",
    "@types/node": "^22.13.0",
    "tsx": "^4.19.0",
    "typescript": "^5.7.0"
  }
}